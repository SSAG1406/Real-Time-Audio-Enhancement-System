    % Save DTMF sequence
    audiowrite('dtmf_test_sequence.wav', dtmf_sequence, fs);
    fprintf('    - DTMF test sequence saved as: dtmf_test_sequence.wav\n');
end

function demonstrate_sample_rate_conversion(signal, fs, config)
    %% Demonstrate sample rate conversion using resample
    fprintf('4. Demonstrating Sample Rate Conversion...\n');
    
    % Use first 2 seconds of audio
    segment_samples = min(2*fs, length(signal));
    x = signal(1:segment_samples);
    
    target_rates = config.target_sample_rates;
    
    for target_fs = target_rates
        if target_fs ~= fs
            fprintf('    Converting from %d Hz to %d Hz...\n', fs, target_fs);
            
            % Use resample for robust and accurate conversion
            y = resample(x, target_fs, fs);
            
            if target_fs < fs
                filename = sprintf('decimated_%dHz.wav', target_fs);
            else
                filename = sprintf('interpolated_%dHz.wav', target_fs);
            end
            
            % Save converted audio
            audiowrite(filename, y, target_fs);
            fprintf('    - Converted audio saved as: %s\n', filename);
        end
    end
end

function demonstrate_dft_idft(signal)
    %% Demonstrate DFT and IDFT properties
    fprintf('5. Demonstrating DFT/IDFT Properties...\n');
    
    % Use a short segment
    N = min(1024, length(signal));
    x = signal(1:N);
    
    % Forward DFT
    X = fft(x);
    
    % Inverse DFT  
    x_reconstructed = ifft(X);
    
    % Verify perfect reconstruction
    reconstruction_error = max(abs(x - x_reconstructed));
    
    fprintf('    - DFT/IDFT perfect reconstruction verified\n');
    fprintf('    - Maximum reconstruction error: %.2e\n', reconstruction_error);
    
    % Demonstrate frequency domain filtering
    % Create a low-pass filter in frequency domain
    cutoff_bin = round(N/4); % Quarter of the spectrum
    X_filtered = X;
    
    % Zero out high frequencies while maintaining symmetry for a real signal
    X_filtered(cutoff_bin + 1 : N - cutoff_bin + 1) = 0;
    
    % Convert back to time domain
    x_filtered = real(ifft(X_filtered));
    
    % Show the effect
    original_energy = sum(x.^2);
    filtered_energy = sum(x_filtered.^2);
    energy_reduction = 10*log10(filtered_energy/original_energy);
    
    fprintf('    - Energy reduction from filtering: %.1f dB\n', energy_reduction);
end

