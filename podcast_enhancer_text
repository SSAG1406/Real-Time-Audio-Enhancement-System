function enhanced_frame = realtime_enhancement(frame, fs, config)
    %% Simplified real-time enhancement for low-latency processing
    
    % Apply high-pass filter to remove rumble
    persistent hp_filter;
    if isempty(hp_filter)
        [b, a] = butter(4, config.highpass_cutoff/(fs/2), 'high');
        hp_filter = struct('b', b, 'a', a, 'z', zeros(max(length(b), length(a))-1, 1));
    end
    
    [enhanced_frame, hp_filter.z] = filter(hp_filter.b, hp_filter.a, frame, hp_filter.z);
    
    % Simple noise gate
    threshold = 0.01;
    gate_mask = abs(enhanced_frame) < threshold;
    enhanced_frame(gate_mask) = enhanced_frame(gate_mask) * 0.1;
    
    % Soft limiting
    enhanced_frame = tanh(enhanced_frame * 2) * 0.5;
end

