function config = setup_enhancement_parameters()
    %% Configure enhancement parameters for professional podcast production
    config = struct();
    
    % Noise reduction parameters
    config.noise_reduction_factor = 0.3;
    config.spectral_floor = -60;  % dB
    
    % Filter parameters
    config.highpass_cutoff = 80;    % Remove low-frequency rumble
    config.lowpass_cutoff = 8000;  % Remove high-frequency noise
    config.eq_bands = [200, 400, 800, 1600, 3200, 6400]; % EQ frequencies
    
    % Dynamic range parameters
    config.compression_ratio = 3;
    config.compression_threshold = -20; % dB
    
    % Window parameters for spectral analysis
    config.window_size = 2048;
    config.overlap = 0.75;
    
    % Sample rate conversion parameters
    config.target_sample_rates = [22050, 48000]; % Common rates
    
    fprintf('Enhancement parameters configured for professional podcast quality\n');
end

function [audio_data, fs] = load_podcast_audio()
    %% Load or simulate podcast audio data
    
    % Try to load actual audio file, otherwise create synthetic podcast audio
    try
        [audio_data, fs] = audioread('raw_podcast_audio.wav');
        fprintf('Loaded existing podcast audio file\n');
    catch
        fprintf('Creating synthetic podcast audio with realistic characteristics...\n');
        [audio_data, fs] = create_synthetic_podcast_audio();
    end
    
    % Normalize audio level
    audio_data = audio_data / max(abs(audio_data)) * 0.8;
end

function [audio_data, fs] = create_synthetic_podcast_audio()
    %% Create realistic synthetic podcast audio for demonstration
    fs = 44100;  % Standard audio sampling rate
    duration = 10;  % seconds
    t = (0:1/fs:duration-1/fs)';
    
    % Generate speech-like signal with multiple harmonics
    fundamental_freq = 150; % Typical male voice fundamental
    speech_signal = zeros(length(t), 1);
    
    % Add harmonics to simulate speech
    for harmonic = 1:8
        amplitude = 1/(harmonic^1.2); % Decreasing amplitude
        freq = fundamental_freq * harmonic;
        if freq < fs/2 % Below Nyquist frequency
            speech_signal = speech_signal + amplitude * sin(2*pi*freq*t);
        end
    end
    
    % Add frequency modulation to simulate natural speech variation
    freq_mod = 0.1 * sin(2*pi*0.5*t); % Slow frequency modulation
    speech_signal = speech_signal .* (1 + freq_mod);
    
    % Add realistic background noise
    noise_level = 0.05;
    background_noise = noise_level * randn(length(t), 1);
    
    % Add 60Hz hum (common electrical interference)
    hum_60hz = 0.02 * sin(2*pi*60*t);
    hum_120hz = 0.01 * sin(2*pi*120*t);
    
    % Add room tone (low-frequency rumble)
    room_tone = 0.03 * sin(2*pi*25*t) + 0.02 * sin(2*pi*35*t);
    
    % Combine all components
    audio_data = speech_signal + background_noise + hum_60hz + hum_120hz + room_tone;
    
    % Apply amplitude variation to simulate natural speech dynamics
    amplitude_envelope = 0.5 + 0.5 * abs(sin(2*pi*0.2*t));
    audio_data = audio_data .* amplitude_envelope;
    
    fprintf('Synthetic podcast audio created with realistic characteristics\n');
end

function enhanced_audio = process_audio_pipeline(audio_data, fs, config)
    %% Main audio processing pipeline using advanced DSP techniques
    
    fprintf('1. Analyzing audio spectrum using FFT...\n');
    % Step 1: Power Density Spectrum analysis for noise characterization
    [~, ~] = estimate_power_spectrum(audio_data, fs, config);
    
    fprintf('2. Applying high-pass FIR filtering...\n');
    % Step 2: High-pass filtering to remove low-frequency rumble (FIR filter)
    enhanced_audio = apply_highpass_filter(audio_data, fs, config.highpass_cutoff);
    
    fprintf('3. Implementing noise reduction...\n');
    % Step 3: Noise reduction using spectral subtraction
    enhanced_audio = apply_noise_reduction(enhanced_audio, fs, config);
    
    fprintf('4. Adding professional EQ using IIR filters...\n');
    % Step 4: Professional EQ using IIR filters
    enhanced_audio = apply_professional_eq(enhanced_audio, fs, config);
    
    fprintf('5. Applying dynamic range compression...\n');
    % Step 5: Dynamic range compression
    enhanced_audio = apply_compression(enhanced_audio, config);
    
    fprintf('6. Final limiting and normalization...\n');
    % Step 6: Final limiting and normalization
    enhanced_audio = apply_final_limiting(enhanced_audio);
    
    fprintf('Audio enhancement pipeline completed!\n');
end

function [psd, freq_vector] = estimate_power_spectrum(signal, fs, config)
    %% Estimate Power Density Spectrum using Welch's method
    
    % Use Welch's method for robust PSD estimation
    window = hann(config.window_size);
    overlap = round(config.window_size * config.overlap);
    nfft = 2^nextpow2(config.window_size);
    
    [psd, freq_vector] = pwelch(signal, window, overlap, nfft, fs);
    
    fprintf('    - Power spectral density estimated using Welch method\n');
end

function filtered_signal = apply_highpass_filter(signal, fs, cutoff_freq)
    %% Apply high-pass FIR filter using windowing technique
    
    % Design FIR high-pass filter using Kaiser window
    filter_order = 100;
    beta = 6; % Kaiser window parameter
    
    % Normalized cutoff frequency
    normalized_cutoff = cutoff_freq / (fs/2);
    
    % Use fir1 function with Kaiser window for optimal FIR filter design
    filter_coeffs = fir1(filter_order, normalized_cutoff, 'high', kaiser(filter_order+1, beta));
    
    % Apply filter using zero-phase filtering to avoid phase distortion
    filtered_signal = filtfilt(filter_coeffs, 1, signal);
    
    fprintf('    - High-pass FIR filter applied (cutoff: %d Hz, Kaiser window)\n', cutoff_freq);
end

function denoised_signal = apply_noise_reduction(signal, fs, config)
    %% Apply noise reduction using spectral subtraction method
    
    window_size = config.window_size;
    overlap = round(window_size * config.overlap);
    NFFT_size = 2 * window_size; % 4096
    
    analysis_window = hann(window_size);
    
    % Convert to frequency domain using STFT
    [S, ~, ~] = spectrogram(signal, analysis_window, overlap, NFFT_size, fs);
    
    % Estimate noise spectrum
    noise_frames = round(0.5 * fs / (window_size - overlap));
    noise_spectrum = mean(abs(S(:, 1:min(noise_frames, size(S,2)))), 2);
    
    % Apply spectral subtraction
    alpha = config.noise_reduction_factor;
    S_denoised = S;
    
    for frame_idx = 1:size(S, 2)
        magnitude = abs(S(:, frame_idx));
        phase = angle(S(:, frame_idx));
        denoised_magnitude = magnitude - alpha * noise_spectrum;
        spectral_floor_val = magnitude * 10^(config.spectral_floor/20);
        denoised_magnitude = max(denoised_magnitude, spectral_floor_val);
        S_denoised(:, frame_idx) = denoised_magnitude .* exp(1j * phase);
    end
    
    % Convert back to time domain
    denoised_complex = istft(S_denoised, fs, ...
        'Window', analysis_window, ...
        'OverlapLength', overlap, ...
        'FFTLength', NFFT_size);
        
    % Take the real part to discard negligible imaginary artifacts
    denoised_signal = real(denoised_complex);
    
    % Trim to original length
    if length(denoised_signal) > length(signal)
        denoised_signal = denoised_signal(1:length(signal));
    end
    
    fprintf('    - Noise reduction applied using spectral subtraction\n');
end

function eq_signal = apply_professional_eq(signal, fs, config)
    %% Apply professional EQ using cascaded IIR filters
    
    eq_signal = signal;
    eq_bands = config.eq_bands;
    
    % Professional podcast EQ curve
    eq_gains = [0, 2, 3, 4, 2, -1]; % dB gains for each band
    
    for band_idx = 1:length(eq_bands)
        center_freq = eq_bands(band_idx);
        gain_db = eq_gains(band_idx);
        Q = 2; % Quality factor
        
        if gain_db ~= 0
            % Design peaking EQ filter (IIR biquad)
            [b, a] = design_peaking_eq(center_freq, gain_db, Q, fs);
            eq_signal = filter(b, a, eq_signal);
        end
    end
    
    fprintf('    - Professional EQ applied using IIR biquad filters\n');
end

function [b, a] = design_peaking_eq(fc, gain_db, Q, fs)
    %% Design peaking EQ filter (IIR biquad section)
    
    % Convert gain to linear
    A = 10^(gain_db/40);
    
    % Pre-warped frequency
    omega = 2 * pi * fc / fs;
    
    % Design coefficients
    alpha_val = sin(omega) / (2 * Q);
    
    % Peaking EQ coefficients
    b0 = 1 + alpha_val * A;
    b1 = -2 * cos(omega);
    b2 = 1 - alpha_val * A;
    
    a0 = 1 + alpha_val / A;
    a1 = -2 * cos(omega);
    a2 = 1 - alpha_val / A;
    
    % Normalize
    b = [b0, b1, b2] / a0;
    a = [1, a1/a0, a2/a0];
end

function compressed_signal = apply_compression(signal, config)
    %% Apply dynamic range compression
    
    ratio = config.compression_ratio;
    threshold_db = config.compression_threshold;
    threshold_linear = 10^(threshold_db/20);
    
    % Simple compression algorithm
    compressed_signal = zeros(size(signal));
    
    for n = 1:length(signal)
        input_level = abs(signal(n));
        
        if input_level > threshold_linear
            % Apply compression above threshold
            over_threshold = input_level / threshold_linear;
            compressed_level = threshold_linear * (over_threshold^(1/ratio));
            compressed_signal(n) = sign(signal(n)) * compressed_level;
        else
            % No compression below threshold
            compressed_signal(n) = signal(n);
        end
    end
    
    fprintf('    - Dynamic range compression applied (ratio: %d:1)\n', ratio);
end

function limited_signal = apply_final_limiting(signal)
    %% Apply final limiting and normalization
    
    % Soft limiting to prevent clipping
    max_level = 0.95;
    limited_signal = tanh(signal / max_level) * max_level;
    
    % Normalize to -1 dBFS
    target_level = 10^(-1/20);
    current_peak = max(abs(limited_signal));
    if current_peak > 0
        limited_signal = limited_signal * (target_level / current_peak);
    end
    
    fprintf('    - Final limiting and normalization applied\n');
end

function display_enhancement_results(original, enhanced, fs, ~)
    %% Display comprehensive analysis of enhancement results
    
    % *** FIX: Ensure signals have the same length for plotting and analysis ***
    minLength = min(length(original), length(enhanced));
    original = original(1:minLength);
    enhanced = enhanced(1:minLength);
    
    figure('Position', [100, 100, 1200, 800], 'Name', 'Audio Enhancement Analysis');
    
    % Time domain comparison
    subplot(3, 2, 1);
    t = (0:length(original)-1)/fs; % Now `t` will match both signals
    plot(t, original, 'b', 'LineWidth', 0.5);
    hold on;
    plot(t, enhanced, 'r', 'LineWidth', 0.8); % This will now work
    title('Time Domain Comparison');
    xlabel('Time (s)');
    ylabel('Amplitude');
    legend('Original', 'Enhanced', 'Location', 'best');
    grid on;
    
    % Frequency domain comparison using FFT
    subplot(3, 2, 2);
    N = length(original);
    f = (0:N-1)*(fs/N);
    
    original_fft = fft(original);
    enhanced_fft = fft(enhanced);
    
    semilogx(f(1:N/2), 20*log10(abs(original_fft(1:N/2))), 'b', 'LineWidth', 1);
    hold on;
    semilogx(f(1:N/2), 20*log10(abs(enhanced_fft(1:N/2))), 'r', 'LineWidth', 1);
    title('Frequency Domain Comparison (FFT)');
    xlabel('Frequency (Hz)');
    ylabel('Magnitude (dB)');
    legend('Original', 'Enhanced', 'Location', 'best');
    grid on;
    xlim([20 fs/2]);
    
    % Power Spectral Density comparison
    subplot(3, 2, 3);
    [psd_orig, f_psd] = pwelch(original, [], [], [], fs);
    [psd_enh, ~] = pwelch(enhanced, [], [], [], fs);
    
    semilogx(f_psd, 10*log10(psd_orig), 'b', 'LineWidth', 1);
    hold on;
    semilogx(f_psd, 10*log10(psd_enh), 'r', 'LineWidth', 1);
    title('Power Spectral Density Comparison');
    xlabel('Frequency (Hz)');
    ylabel('PSD (dB/Hz)');
    legend('Original', 'Enhanced', 'Location', 'best');
    grid on;
    xlim([20 fs/2]);
    
    % Spectrogram of enhanced audio
    subplot(3, 2, 4);
    spectrogram(enhanced, hann(1024), 512, 1024, fs, 'yaxis');
    title('Spectrogram - Enhanced Audio');
    colorbar;
    
    % Dynamic range analysis
    subplot(3, 2, 5);
    dynamic_range_orig = calculate_dynamic_range(original);
    dynamic_range_enh = calculate_dynamic_range(enhanced);
    
    bar([1, 2], [dynamic_range_orig, dynamic_range_enh]);
    set(gca, 'XTickLabel', {'Original', 'Enhanced'});
    title('Dynamic Range Comparison');
    ylabel('Dynamic Range (dB)');
    grid on;
    
    % SNR improvement
    subplot(3, 2, 6);
    snr_orig = calculate_snr(original, fs);
    snr_enh = calculate_snr(enhanced, fs);
    
    bar([1, 2], [snr_orig, snr_enh]);
    set(gca, 'XTickLabel', {'Original', 'Enhanced'});
    title('Signal-to-Noise Ratio');
    ylabel('SNR (dB)');
    grid on;
    
    sgtitle('Smart Audio Enhancement - Analysis Results', 'FontSize', 14, 'FontWeight', 'bold');
    
    % Print summary statistics
    fprintf('\n========== ENHANCEMENT RESULTS ==========\n');
    fprintf('Dynamic Range - Original: %.1f dB, Enhanced: %.1f dB\n', ...
        dynamic_range_orig, dynamic_range_enh);
    fprintf('SNR - Original: %.1f dB, Enhanced: %.1f dB\n', ...
        snr_orig, snr_enh);
    fprintf('Improvement in SNR: %.1f dB\n', snr_enh - snr_orig);
    fprintf('=========================================\n');
end

function dr = calculate_dynamic_range(signal)
    %% Calculate dynamic range of signal
    peak_level = max(abs(signal));
    % Use robust noise floor estimation (e.g., lower percentile of absolute value)
    sorted_abs = sort(abs(signal));
    noise_floor_index = round(length(signal) * 0.05); % 5th percentile
    noise_floor = sorted_abs(noise_floor_index);
    
    % Avoid division by near-zero
    if noise_floor < 1e-9
        dr = Inf;
    else
        dr = 20*log10(peak_level/noise_floor);
    end
end

function snr_db = calculate_snr(signal, fs)
    %% Estimate Signal-to-Noise Ratio
    signal_power = var(signal);
    
    % Estimate noise as high-frequency content (or content above speech range)
    [b, a] = butter(4, 3000/(fs/2), 'high'); % High-pass filter above 3kHz
    noise_estimate = filter(b, a, signal);
    noise_power = var(noise_estimate);
    
    % Guard against zero noise power
    if noise_power < 1e-12
        snr_db = Inf;
    else
        snr_db = 10*log10(signal_power/noise_power);
    end
end

