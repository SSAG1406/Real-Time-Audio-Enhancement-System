function demonstrate_convolution(signal, fs)
    %% Demonstrate circular vs linear convolution for audio effects
    fprintf('1. Demonstrating Circular vs Linear Convolution...\n');
    
    % Use a short segment for demonstration
    segment_length = min(1024, length(signal));
    x = signal(1:segment_length);
    
    % Create impulse response (reverb effect)
    h_length = 256;
    h = exp(-(0:h_length-1)/50)' .* randn(h_length, 1) * 0.3;
    
    % Linear convolution
    y_linear = conv(x, h);
    
    % Circular convolution using DFT (via zero-padding)
    N = length(x) + length(h) - 1;
    Y_circular_fft = fft(x, N) .* fft(h, N);
    y_circular = ifft(Y_circular_fft);
    
    % Compare results
    error = max(abs(y_linear - y_circular));
    fprintf('    - Linear convolution length: %d samples\n', length(y_linear));
    fprintf('    - Error between linear and DFT-based convolution: %.2e\n', error);
    
    % Save demonstration results
    audiowrite('linear_convolution_demo.wav', y_linear/max(abs(y_linear)), fs);
    fprintf('    - Linear convolution result saved as: linear_convolution_demo.wav\n');
end

function demonstrate_windowing_techniques(signal, fs)
    %% Compare different windowing techniques for spectral analysis
    fprintf('2. Comparing Windowing Techniques...\n');
    
    % Use a segment for analysis
    segment_length = min(2048, length(signal));
    x = signal(1:segment_length);
    
    % Different windows
    windows = {
        rectwin(segment_length), 'Rectangular';
        hann(segment_length), 'Hann';
        hamming(segment_length), 'Hamming';
        blackman(segment_length), 'Blackman';
        kaiser(segment_length, 8), 'Kaiser';
        triang(segment_length), 'Triangular'
    };
    
    figure('Position', [200, 200, 1000, 600], 'Name', 'Windowing Techniques Comparison');
    
    for i = 1:size(windows, 1)
        window = windows{i, 1};
        window_name = windows{i, 2};
        
        % Apply window and compute FFT
        windowed_signal = x .* window;
        X = fft(windowed_signal, 4096);
        
        subplot(2, 3, i);
        f = (0:2047) * fs / 4096;
        plot(f, 20*log10(abs(X(1:2048))));
        title([window_name, ' Window']);
        xlabel('Frequency (Hz)');
        ylabel('Magnitude (dB)');
        grid on;
        xlim([20, fs/2]);
        ylim([-100, 0]);
        
        fprintf('    - %s window analysis completed\n', window_name);
    end
    
    sgtitle('Windowing Techniques Comparison for Audio Analysis');
end

function demonstrate_dtmf_generation(fs)
    %% Generate DTMF signals for system testing
    fprintf('3. Generating DTMF Test Signals...\n');
    
    % DTMF frequency pairs
    dtmf_freqs = [
        697, 1209;    % '1'
        697, 1336;    % '2'
        697, 1477;    % '3'
        770, 1209;    % '4'
        770, 1336;    % '5'
        770, 1477;    % '6'
        852, 1209;    % '7'
        852, 1336;    % '8'
        852, 1477;    % '9'
        941, 1336     % '0'
    ];
    
    digit_names = {'1', '2', '3', '4', '5', '6', '7', '8', '9', '0'};
    
    tone_duration = 0.5; % seconds
    t = (0:1/fs:tone_duration-1/fs)';
    
    dtmf_sequence = [];
    
    for i = 1:size(dtmf_freqs, 1)
        low_freq = dtmf_freqs(i, 1);
        high_freq = dtmf_freqs(i, 2);
        
        % Generate dual-tone signal
        tone = 0.5 * (sin(2*pi*low_freq*t) + sin(2*pi*high_freq*t));
        
        % Add to sequence with pause
        pause_samples = round(0.1 * fs); % 100ms pause
        dtmf_sequence = [dtmf_sequence; tone; zeros(pause_samples, 1)]; %#ok<AGROW>
        
        fprintf('    - DTMF digit "%s": %.0f Hz + %.0f Hz\n', ...
            digit_names{i}, low_freq, high_freq);
